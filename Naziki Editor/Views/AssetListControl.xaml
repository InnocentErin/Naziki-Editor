<UserControl x:Class="Naziki_Editor.Views.AssetListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="300">

    <Border Background="#E8E8E8" BorderBrush="Gray" BorderThickness="0,1,1,0">
        <TabControl Background="Transparent" BorderThickness="0" Margin="5">
            <TabItem Header="媒体 (Media)">
                <TreeView x:Name="AssetTreeView" Background="White" BorderBrush="LightGray"/>
            </TabItem>
            <TabItem Header="自建文本">
                <TreeView x:Name="CustomTextTreeView" Background="White" BorderBrush="LightGray"/>
            </TabItem>
            <TabItem Header="自建线条">
                <TreeView x:Name="CustomLineTreeView" Background="White" BorderBrush="LightGray"/>
            </TabItem>
            <TabItem Header="模板库">
                <TreeView x:Name="TemplateTreeView" Background="White" BorderBrush="LightGray"/>
            </TabItem>
        </TabControl>
    </Border>
</UserControl>