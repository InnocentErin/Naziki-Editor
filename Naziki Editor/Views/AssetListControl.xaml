<UserControl x:Class="Naziki_Editor.Views.AssetListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="300" d:DesignWidth="300">

    <UserControl.Resources>
        <DataTemplate x:Key="AssetTileTemplate">
            <Border x:Name="TileBorder" Width="85" Height="100" Margin="5" Padding="5" 
                    Background="{DynamicResource SideBgColor}" CornerRadius="8" BorderThickness="2" BorderBrush="Transparent">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="✏️ 重命名素材" Click="MenuRename_Click"/>
                    </ContextMenu>
                </Border.ContextMenu>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Viewbox Grid.Row="0" Margin="5">
                        <ContentControl Content="{Binding AssetType}">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AssetType}" Value="Image">
                                            <Setter Property="Content" Value="🖼️"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AssetType}" Value="Video">
                                            <Setter Property="Content" Value="🎬"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AssetType}" Value="Text">
                                            <Setter Property="Content" Value="📝"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AssetType}" Value="Line">
                                            <Setter Property="Content" Value="📏"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </Viewbox>

                    <Grid Grid.Row="1" Margin="0,5,0,0">
                        <TextBlock x:Name="TxtDisplay" Text="{Binding DisplayName}" 
                                   Foreground="{DynamicResource MainTextColor}" FontSize="11" TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                   Visibility="Visible"/>

                        <TextBox x:Name="EditBox" Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="Collapsed"
                                 Background="{DynamicResource BoardBgColor}" Foreground="{DynamicResource MainTextColor}" 
                                 BorderThickness="1" BorderBrush="{DynamicResource HighlightBorderColor}"
                                 FontSize="11" TextAlignment="Center" 
                                 KeyDown="EditBox_KeyDown" LostFocus="EditBox_LostFocus" Loaded="EditBox_Loaded"/>
                    </Grid>
                </Grid>
            </Border>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter TargetName="TxtDisplay" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="EditBox" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource HighlightBorderColor}"/>
                    <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource MenuBgColor}"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <ContextMenu x:Key="ListBoxGlobalMenu">
            <MenuItem Header="🔄 刷新素材库 (Scan Assets)" Click="MenuRefresh_Click"/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <TabControl x:Name="AssetTabControl" Background="Transparent" BorderThickness="0" ItemContainerStyle="{DynamicResource HorizontalTabItemStyle}">
            <TabItem Header="媒体">
                <ListBox x:Name="MediaListBox" ItemTemplate="{StaticResource AssetTileTemplate}" SelectionMode="Extended" ContextMenu="{StaticResource ListBoxGlobalMenu}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </TabItem>
            <TabItem Header="文本">
                <ListBox x:Name="TextListBox" ItemTemplate="{StaticResource AssetTileTemplate}" SelectionMode="Extended" ContextMenu="{StaticResource ListBoxGlobalMenu}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </TabItem>
            <TabItem Header="线条">
                <ListBox x:Name="LineListBox" ItemTemplate="{StaticResource AssetTileTemplate}" SelectionMode="Extended" ContextMenu="{StaticResource ListBoxGlobalMenu}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </TabItem>
            <TabItem Header="模板">
                <ListBox x:Name="TemplateListBox" ItemTemplate="{StaticResource AssetTileTemplate}" SelectionMode="Extended" ContextMenu="{StaticResource ListBoxGlobalMenu}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>