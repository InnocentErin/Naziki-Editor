<UserControl x:Class="Naziki_Editor.Views.TimelineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="1000"
             Background="{DynamicResource MainBgColor}" 
             BorderBrush="{DynamicResource BorderColor}"
             Foreground="{DynamicResource MainTextColor}"
             PreviewMouseWheel="OnTimelineMouseWheel">

    <Grid Grid.IsSharedSizeScope="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource MenuBgColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0" HorizontalAlignment="Left">
                    <TextBlock x:Name="TxtCurrentTime" Width="55" Text="0.000s" Foreground="#4DB8FF" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="5,0,15,0"/>
                    <Button x:Name="BtnPlay" Content="▶ 播放" Click="BtnPlay_Click" Margin="0,0,5,0" Padding="10,3" Background="Transparent" Foreground="{DynamicResource MainTextColor}" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="BtnPause" Content="⏸ 暂停" Click="BtnPause_Click" Margin="0,0,15,0" Padding="10,3" Background="Transparent" Foreground="{DynamicResource MainTextColor}" BorderThickness="0" Cursor="Hand"/>
                    <Separator Background="{DynamicResource SeparatorColor}" Margin="0,5"/>
                    <ToggleButton Content="🧲 节拍吸附 (Snap)" Margin="15,0,5,0" Padding="8,3" Background="Transparent" Foreground="{DynamicResource MainTextColor}" BorderThickness="0" Cursor="Hand"/>
                    <ComboBox Width="70" Margin="0,0,15,0" SelectedIndex="1">
                        <ComboBoxItem Content="1/4 拍"/>
                        <ComboBoxItem Content="1/8 拍"/>
                        <ComboBoxItem Content="1/16 拍"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0" HorizontalAlignment="Right">
                    <TextBlock Text="刷新频率:" Foreground="{DynamicResource TipsColor}" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="RefreshRateComboBox" Width="55" SelectedIndex="0" FontSize="11">
                        <ComboBoxItem Content="低"/>
                        <ComboBoxItem Content="高"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="18"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition SharedSizeGroup="TrackHeaderCol" Width="150" MinWidth="100"/>
                    <ColumnDefinition Width="2"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource BoardBgColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"/>
                <ScrollViewer x:Name="ScrollRuler" Grid.Column="2" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                    <Border Width="5000" HorizontalAlignment="Left" Background="{DynamicResource MenuBgColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" MouseLeftButtonDown="Ruler_MouseDown">
                        <Grid>
                            <Canvas x:Name="RulerCanvas"/>
                            <Canvas IsHitTestVisible="False">
                                <Grid x:Name="PlayheadMarker" Width="15" Margin="-7.5,0,0,0" Height="30" Cursor="SizeWE" IsHitTestVisible="True"
                                      MouseLeftButtonDown="Playhead_MouseDown" MouseMove="Playhead_MouseMove" MouseLeftButtonUp="Playhead_MouseUp" Background="Transparent" Panel.ZIndex="999">
                                    <Grid.RenderTransform>
                                        <TranslateTransform x:Name="TransRulerHead" X="0" Y="0"/>
                                    </Grid.RenderTransform>
                                    <Polygon Points="0,0 15,0 15,15 7.5,24 0,15" Fill="#E81123" Stroke="#B30000" StrokeThickness="1"/>
                                </Grid>
                            </Canvas>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition SharedSizeGroup="TrackHeaderCol" Width="150" MinWidth="100"/>
                    <ColumnDefinition Width="2"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource SideBgColor}">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <TextBlock Text="🖼️ Sprites 轨道" Foreground="{DynamicResource TipsColor}" FontSize="10" Margin="10,5,0,0" FontStyle="Italic"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{DynamicResource BorderColor}" Cursor="SizeWE"/>
                <Border Grid.Column="2" Background="{DynamicResource BoardBgColor}">
                    <ScrollViewer x:Name="ScrollSprites" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
                        <Canvas x:Name="SpriteClipCanvas" Width="5000" Height="1000" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <Line Y1="0" Y2="1000" Stroke="#E81123" StrokeThickness="1.5" IsHitTestVisible="False" Panel.ZIndex="999">
                                <Line.RenderTransform>
                                    <TranslateTransform x:Name="TransSpriteLine" X="0" Y="0"/>
                                </Line.RenderTransform>
                            </Line>
                        </Canvas>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="#111111" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition SharedSizeGroup="TrackHeaderCol" Width="150" MinWidth="100"/>
                        <ColumnDefinition Width="2"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🎵 Master Audio" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{DynamicResource BorderColor}" Cursor="SizeWE"/>

                    <ScrollViewer x:Name="ScrollAudio" Grid.Column="2" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                        <Grid x:Name="AudioTrackGrid" Width="5000" HorizontalAlignment="Left">

                            <Canvas>
                                <Path x:Name="WaveformPath" Stroke="#4DB8FF" StrokeThickness="1" Opacity="0.8" Canvas.Top="5"/>
                            </Canvas>

                            <Button x:Name="BtnImportAudio" Panel.ZIndex="20" Content="📥 导入音频文件" Click="BtnImportAudio_Click" Foreground="#4DB8FF" BorderBrush="#4DB8FF" BorderThickness="1" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0" Padding="15,4" Cursor="Hand"/>

                            <Canvas IsHitTestVisible="False" Panel.ZIndex="999">
                                <Line Y1="0" Y2="50" Stroke="#E81123" StrokeThickness="1.5">
                                    <Line.RenderTransform>
                                        <TranslateTransform x:Name="TransAudioLine" X="0" Y="0"/>
                                    </Line.RenderTransform>
                                </Line>
                            </Canvas>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition SharedSizeGroup="TrackHeaderCol" Width="150" MinWidth="100"/>
                    <ColumnDefinition Width="2"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource SideBgColor}">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <TextBlock Text="🎛️ Controllers 轨道" Foreground="{DynamicResource TipsColor}" FontSize="10" Margin="10,5,0,0" FontStyle="Italic"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{DynamicResource BorderColor}" Cursor="SizeWE"/>
                <Border Grid.Column="2" Background="{DynamicResource BoardBgColor}">
                    <ScrollViewer x:Name="ScrollControllers" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
                        <Canvas x:Name="ControllerClipCanvas" Width="5000" Height="1000" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <Line Y1="0" Y2="1000" Stroke="#E81123" StrokeThickness="1.5" IsHitTestVisible="False" Panel.ZIndex="999">
                                <Line.RenderTransform>
                                    <TranslateTransform x:Name="TransCtrlLine" X="0" Y="0"/>
                                </Line.RenderTransform>
                            </Line>
                        </Canvas>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid Grid.Row="4" Background="{DynamicResource MenuBgColor}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition SharedSizeGroup="TrackHeaderCol" Width="150" MinWidth="100"/>
                    <ColumnDefinition Width="2"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource SideBgColor}"/>
                <Border Grid.Column="1" Background="{DynamicResource BorderColor}"/>
                <ScrollViewer x:Name="MasterHorizontalScroll" Grid.Column="2" HorizontalScrollBarVisibility="Visible" VerticalScrollBarVisibility="Hidden" ScrollChanged="OnScrollChanged">
                    <Canvas Width="5000" Height="1" HorizontalAlignment="Left" Background="Transparent"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <Border Grid.Row="3" Background="#1A1A1A" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <Image x:Name="EventMinimapDisplay" Grid.Row="0" Stretch="Fill" Opacity="0.8"/>
                <Image x:Name="ChartMinimapDisplay" Grid.Row="1" Stretch="Fill" Opacity="0.6"/>
                <Border Grid.Row="0" BorderBrush="#333333" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                <Canvas Grid.RowSpan="2">
                    <Border x:Name="MinimapViewportThumb" Height="60" Width="150" Background="#40007ACC" BorderBrush="{DynamicResource HighlightBorderColor}" BorderThickness="1" Cursor="Hand" ToolTip="拖动以快速浏览时间轴"/>
                </Canvas>
            </Grid>
        </Border>
    </Grid>
</UserControl>