<UserControl x:Class="Naziki_Editor.Views.TimelineClipControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="200"
             MinHeight="30" MinWidth="10">

    <Grid x:Name="RootGrid" Background="Transparent" 
          MouseLeftButtonDown="ClipBackground_MouseDown" 
          MouseMove="ClipBackground_MouseMove" 
          MouseLeftButtonUp="ClipBackground_MouseUp">

        <Border x:Name="ClipBackground" Background="#404DB8FF" BorderBrush="#4DB8FF" BorderThickness="1" CornerRadius="3">
            <TextBlock x:Name="ClipNameText" Text="Event Name" Foreground="#CCFFFFFF" FontSize="10" Margin="5,2,0,0" IsHitTestVisible="False"/>
        </Border>

        <Polyline x:Name="OpacityCurve" Stroke="#80FFB84D" StrokeThickness="2" IsHitTestVisible="False" Visibility="Collapsed"/>

        <Canvas x:Name="NodeCanvas" ClipToBounds="True">
        </Canvas>

    </Grid>
</UserControl>