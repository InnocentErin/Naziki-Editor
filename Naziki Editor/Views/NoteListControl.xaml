<UserControl x:Class="Naziki_Editor.Views.NoteListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="300"
             Background="{DynamicResource MainBgColor}" 
             BorderBrush="{DynamicResource BorderColor}"
             Foreground="{DynamicResource MainTextColor}">

    <UserControl.Resources>
        <Style x:Key="FilterButtonStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="False">
                    <Setter Property="Background" Value="{DynamicResource MainBgColor}"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource MainBgColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <WrapPanel Grid.Row="0" Margin="0,0,0,5" HorizontalAlignment="Center">
                <ToggleButton x:Name="FilterClick" Content="Click" Background="LightSeaGreen" Style="{StaticResource FilterButtonStyle}" IsChecked="True" Click="Filter_Click"/>
                <ToggleButton x:Name="FilterCDrag" Content="CDrag" Background="SkyBlue" Style="{StaticResource FilterButtonStyle}" IsChecked="True" Click="Filter_Click"/>
                <ToggleButton x:Name="FilterDrag" Content="Drag" Background="MediumPurple" Style="{StaticResource FilterButtonStyle}" IsChecked="True" Click="Filter_Click"/>
                <ToggleButton x:Name="FilterFlick" Content="Flick" Background="IndianRed" Style="{StaticResource FilterButtonStyle}" IsChecked="True" Click="Filter_Click"/>
                <ToggleButton x:Name="FilterHold" Content="Hold" Background="Magenta" Style="{StaticResource FilterButtonStyle}" IsChecked="True" Click="Filter_Click"/>
                <ToggleButton x:Name="FilterLHold" Content="L-Hold" Background="Gold" Style="{StaticResource FilterButtonStyle}" IsChecked="True" Click="Filter_Click"/>
            </WrapPanel>

            <Grid Grid.Row="1" Background="{DynamicResource MainBgColor}" Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="SearchMode" Grid.Column="0" SelectedIndex="0" FontSize="10" Background="{DynamicResource MainBgColor}" Margin="0,0,5,0">
                    <ComboBoxItem Content="按时间(s)"/>
                    <ComboBoxItem Content="按 X轴"/>
                </ComboBox>
                <TextBox x:Name="SearchMinBox" Grid.Column="1" MaxLength="10" FontSize="10" VerticalContentAlignment="Center"/>
                <TextBlock Grid.Column="2" Text=" ~ " VerticalAlignment="Center" FontSize="10"/>
                <TextBox x:Name="SearchMaxBox" Grid.Column="3" MaxLength="10" FontSize="10" VerticalContentAlignment="Center"/>
                <Button x:Name="BtnSearch" Grid.Column="4" Content="🔍 搜索" FontSize="10" Margin="5,0,0,0" Padding="5,0" Click="BtnSearch_Click"/>
            </Grid>

            <Grid Grid.Row="2" Background="{DynamicResource MainBgColor}" Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="65"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="选" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <Button Grid.Column="1" Content="ID ▲" FontSize="10" Padding="0"/>
                <TextBlock Grid.Column="2" Text=" 时间(秒)" FontSize="10" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text=" 类型" FontSize="10" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text=" X轴" FontSize="10" VerticalAlignment="Center"/>
            </Grid>

            <TreeView x:Name="NoteTreeView" Grid.Row="3" Background="{DynamicResource MainBgColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,1"/>
            <Grid Grid.Row="4" Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="SelectAllChk" Grid.Column="0" Content="当前全选" FontSize="11" VerticalAlignment="Center"/>
                <Button x:Name="ImportEventBtn" Grid.Column="1" Content="🚀 一键导入事件" FontSize="11" HorizontalAlignment="Right" Padding="10,2" Background="LightGreen"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>