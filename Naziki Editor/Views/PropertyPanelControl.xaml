<UserControl x:Class="Naziki_Editor.Views.PropertyPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Naziki_Editor.Models"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="300">

    <Border Background="{DynamicResource MainBgColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 动态属性表单区域 -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PropertyContainer" Margin="15">
                    <!-- 这里会在代码中动态添加属性行 -->
                    <TextBlock Text="未选中任何对象" 
                               Foreground="{DynamicResource TipsColor}" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               Margin="0,20,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮栏 -->
            <UniformGrid Grid.Row="1" Columns="2" Margin="15,10">
                <Button x:Name="BtnEditProperties" Content="编辑属性" Click="BtnEditProperties_Click"
                        Background="{DynamicResource HighlightBorderColor}" Foreground="White" FontWeight="Bold"
                        Padding="15,8" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="BtnSaveAsMaterial" Content="⭐ 存为预设素材" Click="BtnSaveAsMaterial_Click"
                        Background="DarkOrange" Foreground="White" FontWeight="Bold"
                        Padding="15,8" Margin="5,0,0,0" BorderThickness="0" Cursor="Hand"/>
            </UniformGrid>
        </Grid>
    </Border>
</UserControl>