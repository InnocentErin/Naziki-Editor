<UserControl x:Class="Naziki_Editor.Views.PropertyEditor.PropertyEditor_InitialState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{DynamicResource MainTextColor}">
    <Grid>
        <StackPanel x:Name="PanelUninitialized" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20" Visibility="Visible">
            <TextBlock Text="⚠️ 当前对象尚未初始化，缺少关键的第 0 帧 (States[0])！" Foreground="#FF5555" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="必须创建初始属性后，才能保存该对象并对其进行编辑。" Foreground="{DynamicResource TipsColor}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            <Button x:Name="BtnCreateInitial" Content="➕ 立即生成初始属性 (Init States)" Padding="20,10" Background="#4DB8FF" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel x:Name="PanelProperties" Visibility="Collapsed" Orientation="Vertical">

            <Grid x:Name="RowTime" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="初始时间 (Time):" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="TxtTime" Grid.Column="1" Padding="5" ToolTip="例如 0, 1.5, 或者 start:841"/>
            </Grid>

            <Grid x:Name="RowX" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="初始 X 坐标:" VerticalAlignment="Center" FontWeight="Bold"/>
                <ComboBox x:Name="CmbUnitX" Grid.Column="1" Margin="0,0,5,0" SelectedIndex="0">
                    <ComboBoxItem Content="默认 (纯数字)" Tag="World"/>
                    <ComboBoxItem Content="舞台空间 (stageX)" Tag="StageX"/>
                    <ComboBoxItem Content="游玩空间 (noteX)" Tag="NoteX"/>
                    <ComboBoxItem Content="相机空间 (cameraX)" Tag="CameraX"/>
                </ComboBox>
                <TextBox x:Name="TxtValueX" Grid.Column="2" Padding="5" ToolTip="填入具体的数值，例如 0.5"/>
            </Grid>

            <Grid x:Name="RowY" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="初始 Y 坐标:" VerticalAlignment="Center" FontWeight="Bold"/>
                <ComboBox x:Name="CmbUnitY" Grid.Column="1" Margin="0,0,5,0" SelectedIndex="0">
                    <ComboBoxItem Content="默认 (纯数字)" Tag="World"/>
                    <ComboBoxItem Content="舞台空间 (stageY)" Tag="StageY"/>
                    <ComboBoxItem Content="游玩空间 (noteY)" Tag="NoteY"/>
                    <ComboBoxItem Content="相机空间 (cameraY)" Tag="CameraY"/>
                </ComboBox>
                <TextBox x:Name="TxtValueY" Grid.Column="2" Padding="5" ToolTip="填入具体的数值，例如 0.5"/>
            </Grid>

            <Grid x:Name="RowOpacity" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="初始透明度 (Opacity):" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="TxtOpacity" Grid.Column="1" Padding="5" ToolTip="0.0 (全透明) 到 1.0 (不透明)"/>
            </Grid>

            <TextBlock Text="💡 提示：颜色、旋转等更多专有属性，请在下方【选中帧参数编辑】模块中调整。" Foreground="{DynamicResource TipsColor}" FontStyle="Italic" Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>