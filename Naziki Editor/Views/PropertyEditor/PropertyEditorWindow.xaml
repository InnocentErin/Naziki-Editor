<Window x:Class="Naziki_Editor.Views.PropertyEditor.PropertyEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Naziki_Editor.Views.PropertyEditor" 
        Title="属性编辑器" 
        Height="760" Width="1000"
        
        MinWidth="950" 
        MinHeight="680"
        MaxWidth="1600" 
        MaxHeight="1050"
        
        WindowStartupLocation="CenterOwner" 
        ShowInTaskbar="False"
        Background="{DynamicResource MainBgColor}" 
        Foreground="{DynamicResource MainTextColor}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button x:Name="BtnCancel" Content="取消 (Cancel)" Padding="20,8" Margin="0,0,10,0" Background="Transparent" Foreground="{DynamicResource MainTextColor}" BorderBrush="{DynamicResource BorderColor}" Cursor="Hand"/>
            <Button x:Name="BtnSave" Content="💾 确认并保存魔法" Padding="20,8" Background="{DynamicResource HighlightBorderColor}" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <GroupBox Grid.Row="1" Header="🎭 对象基础身份 (Identity)" BorderBrush="{DynamicResource BorderColor}" Foreground="{DynamicResource TipsColor}" Margin="0,0,0,10">
            <local:PropertyEditor_Identity x:Name="ModIdentity" Margin="5"/>
        </GroupBox>

        <!-- <GroupBox Grid.Row="2" Header="🎬 初始属性 (Root Properties)" BorderBrush="{DynamicResource BorderColor}" Foreground="{DynamicResource TipsColor}" Margin="0,0,0,10">
           <local:PropertyEditor_InitialState x:Name="ModInitialState" Margin="5"/> 
        </GroupBox> -->
        
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="🎞️ 状态关键帧 (States)" BorderBrush="{DynamicResource BorderColor}" Foreground="{DynamicResource TipsColor}">
                <local:PropertyEditor_FrameList x:Name="ModFrameList" Margin="5"/>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="⚙️ 选中帧参数编辑 (Active Track Details)" BorderBrush="{DynamicResource BorderColor}" Foreground="{DynamicResource TipsColor}">
                <local:PropertyEditor_FrameDetails x:Name="ModFrameDetails" Margin="5"/>
            </GroupBox>
        </Grid>
    </Grid>
</Window>