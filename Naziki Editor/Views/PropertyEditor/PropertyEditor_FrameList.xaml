<UserControl x:Class="Naziki_Editor.Views.PropertyEditor.PropertyEditor_FrameList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{DynamicResource MainTextColor}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🎬 关键帧轨道 (States)" FontWeight="Bold" Margin="5"/>

        <ListBox x:Name="ListFrames" Grid.Row="1" Margin="5" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource MainTextColor}" SelectionChanged="ListFrames_SelectionChanged"/>

        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="5">
            <Button x:Name="BtnAddFrame" Content="➕ 创建初始状态 (States[0])" Padding="10,8" Margin="0,0,0,5" Background="#FF5555" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnAddFrame_Click"/>
            <Button x:Name="BtnRemoveFrame" Content="🗑️ 删除选中帧" Padding="10,5" Background="#555555" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnRemoveFrame_Click"/>
        </StackPanel>
    </Grid>
</UserControl>