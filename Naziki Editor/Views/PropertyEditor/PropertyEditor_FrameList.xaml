<UserControl x:Class="Naziki_Editor.Views.PropertyEditor.PropertyEditor_FrameList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{DynamicResource MainTextColor}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🎬 状态关键帧轨道 (States Hierarchy)" FontWeight="Bold" Margin="5"/>

        <TreeView x:Name="TreeFrames" Grid.Row="1" Margin="5" 
                  Background="Transparent" Foreground="{DynamicResource MainTextColor}"
                  SelectedItemChanged="TreeFrames_SelectedItemChanged">
            <TreeView.Resources>
                <Style TargetType="TreeViewItem">
                    <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
                    <Setter Property="IsExpanded" Value="True"/>
                    <Setter Property="Padding" Value="3"/>
                </Style>
            </TreeView.Resources>
        </TreeView>

        <Grid Grid.Row="2" Margin="5">
            <Grid.ColumnDefinitions>
                <Grid.ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BtnAddGroup" Content="➕ 添加状态组" Padding="5,8" Margin="0,0,2,0" 
                    Background="#4DB8FF" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnAddGroup_Click"/>
            <Button x:Name="BtnRemove" Content="🗑️ 删除选中帧/状态组" Padding="5,8" Margin="2,0,0,0" 
                    Background="#555555" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnRemove_Click"/>
        </Grid>
    </Grid>
</UserControl>