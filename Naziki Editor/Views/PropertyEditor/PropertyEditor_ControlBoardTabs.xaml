<UserControl x:Class="Naziki_Editor.Views.PropertyEditor.PropertyEditor_ControlBoardTabs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="RootContainer">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TabControl x:Name="TabControlBoards" SelectionChanged="TabControlBoards_SelectionChanged" Background="Transparent" BorderThickness="0" Margin="0,0,10,0"/>

        <Button x:Name="BtnDeleteControlBoard" Grid.Column="1" Content="🗑️ 销毁此板" Padding="10,5" Margin="0,0,5,0" Background="IndianRed" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnDeleteControlBoard_Click" Visibility="Collapsed"/>
        <Button x:Name="BtnAddControlBoard" Grid.Column="2" Content="➕ 添加控制板" Padding="10,5" Background="MediumPurple" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnAddControlBoard_Click"/>
    </Grid>
</UserControl>