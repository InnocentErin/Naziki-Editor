<UserControl x:Class="Naziki_Editor.Views.PropertyEditor.PropertyEditor_Identity"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{DynamicResource MainTextColor}">
    <StackPanel Orientation="Vertical">

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="对象 ID:" VerticalAlignment="Center" FontWeight="Bold"/>
            <StackPanel Grid.Column="1" Orientation="Vertical">
                <TextBox x:Name="TxtObjectId" Padding="5" ToolTip="全局唯一身份证，不能与别人重名哦！"/>
                <TextBlock x:Name="TxtIdWarning" Text="⚠️ ID 冲突或为空！" Foreground="#FF5555" FontWeight="Bold" Margin="0,5,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="跟随目标 (Parent):" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox x:Name="TxtParentId" Grid.Column="1" Padding="5" ToolTip="填入其他场景对象或音符的ID，留空则代表不跟随"/>

            <Button x:Name="BtnBindEvent" Grid.Column="2" Content="🔗 绑定事件" Margin="5,0,0,0" Padding="10,0" Background="#4DB8FF" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                <Button.ContextMenu>
                    <ContextMenu x:Name="MenuEventList" />
                </Button.ContextMenu>
            </Button>

            <Button x:Name="BtnBindNote" Grid.Column="3" Content="🎵 绑定谱面音符" Margin="5,0,0,0" Padding="10,0" Background="#FF6B6B" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" IsEnabled="False" ToolTip="需要先在主界面导入谱面哦！">
                <Button.ContextMenu>
                    <ContextMenu x:Name="MenuNoteList" />
                </Button.ContextMenu>
            </Button>
        </Grid>

        <Grid x:Name="RowTemplateType" Margin="0,0,0,10" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions> 
            <TextBlock Text="模板门派分类:" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource HighlightBorderColor}"/>
            <ComboBox x:Name="CmbTemplateType" Grid.Column="1" Padding="5" SelectionChanged="CmbTemplateType_SelectionChanged">
                <ComboBoxItem Content="🌍 混沌通用 (Generic)" Tag="Generic"/>
                <ComboBoxItem Content="📦 场景对象 (StageObject)" Tag="StageObject"/>
                <ComboBoxItem Content="📝 文本专用 (Text)" Tag="Text"/>
                <ComboBoxItem Content="🖼️ 精灵专用 (Sprite)" Tag="Sprite"/>
                <ComboBoxItem Content="🎥 视频专用 (Video)" Tag="Video"/>
                <ComboBoxItem Content="〰️ 线条专用 (Line)" Tag="Line"/>
                <ComboBoxItem Content="🎛️ 场景控制/滤镜 (Controller)" Tag="Controller"/>
                <ComboBoxItem Content="🎵 音符控制器 (NoteController)" Tag="NoteController"/>
            </ComboBox>
        </Grid>
        
        
    </StackPanel>
</UserControl>