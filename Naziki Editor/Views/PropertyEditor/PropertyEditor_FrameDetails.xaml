<UserControl x:Class="Naziki_Editor.Views.PropertyEditor.PropertyEditor_FrameDetails"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{DynamicResource MainTextColor}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PanelDetails" Margin="10" Visibility="Collapsed">
                <TextBlock x:Name="TxtFrameTitle" Text="🎬 当前编辑: [0] 初始状态" FontWeight="Bold" FontSize="14" Margin="0,0,0,15" Foreground="{DynamicResource HighlightBorderColor}"/>

                <Grid x:Name="RowTime" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="时间 (Time):" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="TxtTime" Grid.Column="1" Padding="5"/>
                </Grid>

                <Grid x:Name="RowX" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="X 坐标:" VerticalAlignment="Center" FontWeight="Bold"/>
                    <ComboBox x:Name="CmbUnitX" Grid.Column="1" Margin="0,0,5,0">
                        <ComboBoxItem Content="默认 (纯数字)" Tag="World"/>
                        <ComboBoxItem Content="舞台 (stageX)" Tag="StageX"/>
                        <ComboBoxItem Content="游玩 (noteX)" Tag="NoteX"/>
                        <ComboBoxItem Content="相机 (cameraX)" Tag="CameraX"/>
                    </ComboBox>
                    <TextBox x:Name="TxtValueX" Grid.Column="2" Padding="5"/>
                </Grid>

                <Grid x:Name="RowY" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Y 坐标:" VerticalAlignment="Center" FontWeight="Bold"/>
                    <ComboBox x:Name="CmbUnitY" Grid.Column="1" Margin="0,0,5,0">
                        <ComboBoxItem Content="默认 (纯数字)" Tag="World"/>
                        <ComboBoxItem Content="舞台 (stageY)" Tag="StageY"/>
                        <ComboBoxItem Content="游玩 (noteY)" Tag="NoteY"/>
                        <ComboBoxItem Content="相机 (cameraY)" Tag="CameraY"/>
                    </ComboBox>
                    <TextBox x:Name="TxtValueY" Grid.Column="2" Padding="5"/>
                </Grid>

                <Grid x:Name="RowZ" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Z 坐标 (层级):" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="TxtZ" Grid.Column="1" Padding="5"/>
                </Grid>

                <Grid x:Name="RowRotZ" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="旋转 Z (角度):" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="TxtRotZ" Grid.Column="1" Padding="5"/>
                </Grid>

                <Grid x:Name="RowScale" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="缩放 (Scale):" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="TxtScaleX" Grid.Column="1" Padding="5" ToolTip="X 轴缩放"/>
                    <TextBlock Text=" , " Grid.Column="2" VerticalAlignment="Center" FontWeight="Bold" Margin="5,0"/>
                    <TextBox x:Name="TxtScaleY" Grid.Column="3" Padding="5" ToolTip="Y 轴缩放"/>
                </Grid>

                <Grid x:Name="RowColor" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="颜色 (Color):" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="TxtColorHex" Grid.Column="1" Padding="5" ToolTip="哈希值，例如 #FFFFFF"/>
                    <Button x:Name="BtnPickColor" Grid.Column="2" Content="🎨 选色盘..." Padding="10,0" Margin="5,0,0,0" Cursor="Hand" Click="BtnPickColor_Click"/>
                </Grid>

                <Grid x:Name="RowOpacity" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="透明度 (Opacity):" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="TxtOpacity" Grid.Column="1" Padding="5"/>
                </Grid>

                <Separator Margin="0,10"/>

                <Grid x:Name="RowEasing" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="动画缓动 (Easing):" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="TxtEasing" Grid.Column="1" Padding="5" ToolTip="缓动曲线类型" IsReadOnly="False"/>
                    <Button x:Name="BtnPickEasing" Grid.Column="2" Content="🌊 选择缓动..." Padding="10,0" Margin="5,0,0,0" Cursor="Hand" Click="BtnPickEasing_Click"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <TextBlock x:Name="TxtEmptyState" Text="👈 请先在左侧选择一个关键帧进行编辑" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TipsColor}"/>
    </Grid>
</UserControl>