<UserControl x:Class="Naziki_Editor.Views.PropertyEditor.PropertyEditor_FrameDetails"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{DynamicResource MainTextColor}">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PanelDetails" Margin="10" Visibility="Collapsed">
                <TextBlock x:Name="TxtFrameTitle" Text="🎬 当前编辑: [x]" FontWeight="Bold" FontSize="14" Margin="0,0,0,15" Foreground="{DynamicResource HighlightBorderColor}"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="时间 (Time):" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="TxtTime" Grid.Column="1" Padding="5"/>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="动画缓动 (Easing):" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="TxtEasing" Grid.Column="1" Padding="5" ToolTip="例如 linear, easeOutQuad"/>
                </Grid>

                <Separator Margin="0,10"/>
                <TextBlock Text="🎨 已启用的属性面板:" FontWeight="Bold" Margin="0,0,0,10"/>

                <StackPanel x:Name="PanelDynamicProperties" />

                <Separator Margin="0,10"/>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="增加新属性:" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource TipsColor}"/>
                    <ComboBox x:Name="CmbAvailableProperties" Grid.Column="1" Margin="0,0,5,0"/>
                    <Button x:Name="BtnAddProperty" Grid.Column="2" Content="➕ 开启此属性" Padding="10,5" Cursor="Hand" Click="BtnAddProperty_Click"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <TextBlock x:Name="TxtEmptyState" Text="👈 请先在左侧选择一个关键帧进行编辑" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TipsColor}"/>
    </Grid>
</UserControl>