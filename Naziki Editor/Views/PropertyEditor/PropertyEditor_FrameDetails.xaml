<UserControl x:Class="Naziki_Editor.Views.PropertyEditor.PropertyEditor_FrameDetails"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{DynamicResource MainTextColor}">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PanelDetails" Margin="10" Visibility="Collapsed">
                <TextBlock x:Name="TxtFrameTitle" Text="🎬 当前编辑: [x]" FontWeight="Bold" FontSize="14" Margin="0,0,0,15" Foreground="{DynamicResource HighlightBorderColor}"/>

                <Border Background="{DynamicResource MenuBgColor}" CornerRadius="5" Padding="10" Margin="0,0,0,15" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="✨ 挂载模板印章 (Template)" FontWeight="Bold" Margin="0,0,0,5" Foreground="{DynamicResource SecTextColor}"/>
                        <ComboBox x:Name="CmbTemplate" Padding="5" SelectionChanged="CmbTemplate_SelectionChanged"/>
                    </StackPanel>
                </Border>
                
                <Border Background="{DynamicResource MenuBgColor}" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="⏱️ 基础时间轴轴心参数" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource SecTextColor}"/>
                        <Grid Margin="0,0,0,8" x:Name="RowTime">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="触发时间 (Time):" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="TxtTime" Grid.Column="1" Padding="5"/>
                        </Grid>
                        <Grid Margin="0,0,0,8" x:Name="RowEasing">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="过渡缓动 (Easing):" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="TxtEasing" Grid.Column="1" Padding="5"/>
                        </Grid>
                        <StackPanel x:Name="PanelStateTimeOptions" Visibility="Collapsed">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="附加时间 (AddTime):" VerticalAlignment="Center" Foreground="{DynamicResource TipsColor}"/>
                                <TextBox x:Name="TxtAddTime" Grid.Column="1" Padding="5"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="相对时间 (RelativeTime):" VerticalAlignment="Center" Foreground="{DynamicResource TipsColor}"/>
                                <TextBox x:Name="TxtRelativeTime" Grid.Column="1" Padding="5"/>
                            </Grid>
                            
                            <Grid Margin="0,0,0,10">
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="图层 (Layer)" FontSize="10" Foreground="{DynamicResource TipsColor}" Margin="0,0,0,2"/>
                                    <TextBox x:Name="TxtLayer" Padding="4" ToolTip="大图层分组 (仅初始帧可编辑)"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="优先级 (Order)" FontSize="10" Foreground="{DynamicResource TipsColor}" Margin="0,0,0,2"/>
                                    <TextBox x:Name="TxtOrder" Padding="4" ToolTip="同图层内的上下遮挡关系 (仅初始帧可编辑)"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel x:Name="PanelSceneCards" Visibility="Collapsed">
                    <Expander Header="📍 空间坐标与尺寸控制" IsExpanded="True" Margin="0,0,0,10" FontWeight="Bold">
                        <Border BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Padding="10" CornerRadius="0,0,5,5" Margin="0,5,0,0">
                            <StackPanel>
                                <StackPanel x:Name="PanelSpatialContainer" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="CmbSpatialProps" FontWeight="Normal"/>
                                    <Button x:Name="BtnAddSpatial" Grid.Column="1" Content="➕ 开启属性" Padding="12,4" Margin="5,0,0,0" Click="BtnAddSpatial_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Expander>
                    <Expander Header="🎨 外观颜色与表现控制" IsExpanded="True" Margin="0,0,0,10" FontWeight="Bold">
                        <Border BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Padding="10" CornerRadius="0,0,5,5" Margin="0,5,0,0">
                            <StackPanel>
                                <StackPanel x:Name="PanelAppearanceContainer" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="CmbAppearanceProps" FontWeight="Normal"/>
                                    <Button x:Name="BtnAddAppearance" Grid.Column="1" Content="➕ 开启属性" Padding="12,4" Margin="5,0,0,0" Click="BtnAddAppearance_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Expander>
                </StackPanel>

                <StackPanel x:Name="PanelControllerCards" Visibility="Collapsed">
                    <Expander Header="📱 全局游戏 UI 控制" IsExpanded="True" Margin="0,0,0,10" FontWeight="Bold">
                        <Border BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Padding="10" CornerRadius="0,0,5,5" Margin="0,5,0,0">
                            <StackPanel>
                                <StackPanel x:Name="PanelUiContainer" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="CmbUiProps" FontWeight="Normal"/>
                                    <Button x:Name="BtnAddUiProp" Grid.Column="1" Content="➕ 开启属性" Padding="12,4" Margin="5,0,0,0" Click="BtnAddUiProp_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Expander>
                    <Expander Header="🎥 核心相机系统" IsExpanded="True" Margin="0,0,0,10" FontWeight="Bold">
                        <Border BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Padding="10" CornerRadius="0,0,5,5" Margin="0,5,0,0">
                            <StackPanel>
                                <StackPanel x:Name="PanelCameraContainer" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="CmbCameraProps" FontWeight="Normal"/>
                                    <Button x:Name="BtnAddCameraProp" Grid.Column="1" Content="➕ 开启属性" Padding="12,4" Margin="5,0,0,0" Click="BtnAddCameraProp_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Expander>
                    <Expander Header="✨ 屏幕画面滤镜 (Filters)" IsExpanded="False" Margin="0,0,0,10" FontWeight="Bold">
                        <Border BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Padding="10" CornerRadius="0,0,5,5" Margin="0,5,0,0">
                            <StackPanel>
                                <StackPanel x:Name="PanelEffectsContainer" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="CmbEffectsProps" FontWeight="Normal"/>
                                    <Button x:Name="BtnAddEffectsProp" Grid.Column="1" Content="➕ 开启属性" Padding="12,4" Margin="5,0,0,0" Click="BtnAddEffectsProp_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Expander>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
        <TextBlock x:Name="TxtEmptyState" Text="👈 请先在左侧轨道选择一个状态层" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TipsColor}"/>
    </Grid>
</UserControl>