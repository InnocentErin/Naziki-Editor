<Window x:Class="Naziki_Editor.ProjectManagement.ProjectHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Naziki Editor - 项目启动中心" Height="450" Width="750"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource MainBgColor}" 
        Foreground="{DynamicResource MainTextColor}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SideBgColor}">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="🕒 最近打开的项目" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="{DynamicResource SecTextColor}"/>

                <ListBox x:Name="HistoryListBox" Grid.Row="1" Background="Transparent" BorderThickness="0" 
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <TextBlock Text="暂无历史记录..." Foreground="{DynamicResource TipsColor}" FontStyle="Italic" Margin="10"/>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource BorderColor}"/>

        <Grid Grid.Column="2" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Naziki Editor" FontSize="36" FontWeight="Heavy" Foreground="{DynamicResource HighlightBorderColor}" HorizontalAlignment="Center"/>
                <TextBlock Text="Version 1.0.0" FontSize="12" Foreground="{DynamicResource TipsColor}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <Button x:Name="BtnCreateProject" Grid.Row="1" Content="✨ 新建项目 (Create New)" 
                    Background="{DynamicResource HighlightBorderColor}" Foreground="White" 
                    FontSize="16" FontWeight="Bold" Padding="15,12" Margin="0,20,0,10" 
                    BorderThickness="0" Cursor="Hand" Click="BtnCreateProject_Click"/>

            <Button x:Name="BtnOpenProject" Grid.Row="2" Content="📂 打开项目 (Open Project)" 
                    Background="Transparent" Foreground="{DynamicResource MainTextColor}" 
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                    FontSize="16" Padding="15,12" Margin="0,0,0,20" 
                    Cursor="Hand" Click="BtnOpenProject_Click"/>
        </Grid>
    </Grid>
</Window>