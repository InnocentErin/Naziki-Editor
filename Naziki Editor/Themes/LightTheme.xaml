<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="MainBgColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BoardBgColor" Color="#F9F9F9"/>
    <SolidColorBrush x:Key="SideBgColor" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="MenuBgColor" Color="#F5F5F5"/>

    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="MainTextColor" Color="#000000"/>
    <SolidColorBrush x:Key="SecTextColor" Color="#666666"/>
    <SolidColorBrush x:Key="TipsColor" Color="Gray"/>

    <SolidColorBrush x:Key="BorderColor" Color="LightGray"/>
    <SolidColorBrush x:Key="SeparatorColor" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="HighlightBorderColor" Color="#007ACC"/>
    <SolidColorBrush x:Key="HighlightColor" Color="#007ACC"/>

    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#000000"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FFFFFF"/>


<!-- 以下是针对时间轴剪辑的专用颜色资源，保持与整体浅色调一致但具有区分度-->
    <SolidColorBrush x:Key="SpriteClipBgBrush" Color="#E2F0D9"/>
    <SolidColorBrush x:Key="SpriteClipBorderBrush" Color="#388E3C"/>
    <SolidColorBrush x:Key="TextClipBgBrush" Color="#DDEBF7"/>
    <SolidColorBrush x:Key="TextClipBorderBrush" Color="#1F75FE"/>
    <SolidColorBrush x:Key="VideoClipBgBrush" Color="#FFF2CC"/>
    <SolidColorBrush x:Key="VideoClipBorderBrush" Color="#F39C12"/>

    <SolidColorBrush x:Key="ClipTextBrush" Color="#333333"/>
    <SolidColorBrush x:Key="VirtualLineBrush" Color="#CC2222"/>

</ResourceDictionary>