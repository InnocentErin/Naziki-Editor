<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<!-- 以下是暗色主题的核心颜色资源定义，确保整个界面在暗色调下具有统一且舒适的视觉体验 -->
    <SolidColorBrush x:Key="MainBgColor" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="BoardBgColor" Color="#252526"/>
    <SolidColorBrush x:Key="SideBgColor" Color="#2D2D30"/>
    <SolidColorBrush x:Key="MenuBgColor" Color="#2D2D30"/>
<!--下面是一些基础的界面元素颜色定义，确保在暗色主题下有足够的对比度和视觉层次感-->
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#1E1E1E"/>

<!--下面是一些基础的文本颜色定义，确保在暗色主题下有足够的可读性和层次感-->
        <SolidColorBrush x:Key="MainTextColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecTextColor" Color="#A0A0A0"/>
    <SolidColorBrush x:Key="TipsColor" Color="#555555"/>

<!--下面是一些通用的界面元素颜色定义，确保在暗色主题下有足够的对比度和视觉层次感-->
    <SolidColorBrush x:Key="BorderColor" Color="#3F3F46"/>
    <SolidColorBrush x:Key="SeparatorColor" Color="#333333"/>
    <SolidColorBrush x:Key="HighlightBorderColor" Color="#007ACC"/>
    <SolidColorBrush x:Key="HighlightColor" Color="#4DB8FF"/>
    
<!--下面是覆盖系统默认颜色资源的定义，确保内置控件（如菜单、工具栏等）在暗色主题下也能保持一致的视觉风格-->
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#2D2D30"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1E1E1E"/>




<!--以下是针对时间轴剪辑的专用颜色资源，保持与整体暗色调一致但具有区分度-->
    <SolidColorBrush x:Key="SpriteClipBgBrush" Color="#254D2A"/>
    <SolidColorBrush x:Key="SpriteClipBorderBrush" Color="#55C066"/>
    <SolidColorBrush x:Key="TextClipBgBrush" Color="#1E3D59"/>
    <SolidColorBrush x:Key="TextClipBorderBrush" Color="#4DB8FF"/>
    <SolidColorBrush x:Key="VideoClipBgBrush" Color="#593E1A"/>
    <SolidColorBrush x:Key="VideoClipBorderBrush" Color="#FF9F43"/>
    <SolidColorBrush x:Key="ClipTextBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="VirtualLineBrush" Color="#FF5555"/>


</ResourceDictionary>